@page "/individuals/{Id}/edit"
@rendermode InteractiveServer

<PageTitle>手持ち編集</PageTitle>

<h1>手持ち編集</h1>

@if (isLoading_)
{
    <p>読み込み中...</p>
}
else if (notFound_)
{
    <Alert Variant="AlertVariant.Warning">指定された個体が見つかりませんでした。</Alert>
    <Button Variant="ButtonVariant.Secondary" Href="individuals">一覧に戻る</Button>
}
else
{
    <IndividualForm SubmitLabel="更新"
                    OnSubmit="HandleSubmit"
                    ErrorMessage="@errorMessage_"
                    IsSubmitting="@isSubmitting_"
                    FormData="formData_"
                    Model="model_" />
}
