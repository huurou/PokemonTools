@using PokemonTools.Web.Domain.Types
@using PokemonTools.Web.Domain.Statistics

<div class="row">
    <div class="col-md-8">
        <div class="mb-3">
            <label class="form-label">種族 <span class="text-danger">*</span></label>
            <input type="text" class="form-control mb-1" placeholder="種族名で検索..." @bind="speciesFilter_" @bind:event="oninput" />
            <select class="form-select" @bind="SelectedSpeciesId" @bind:after="HandleSpeciesChangeAsync">
                <option value="0">-- 選択してください --</option>
                @foreach (var species in FilteredSpecies)
                {
                    <option value="@species.Id.Value">@species.Name</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">ニックネーム</label>
            <input type="text" class="form-control" @bind="Name" @bind:after="() => NameChanged.InvokeAsync(Name)" placeholder="未入力の場合は種族名で表示" />
        </div>

        <div class="mb-3">
            <label class="form-label">能力補正 <span class="text-danger">*</span></label>
            <select class="form-select" @bind="SelectedStatAlignmentId" @bind:after="() => SelectedStatAlignmentIdChanged.InvokeAsync(SelectedStatAlignmentId)">
                @foreach (var sa in StatAlignment.All)
                {
                    var label = sa.IncreasedStat.HasValue
                        ? $"{sa.Name}（{GetStatName(sa.IncreasedStat.Value)}↑ {GetStatName(sa.DecreasedStat!.Value)}↓）"
                        : $"{sa.Name}（補正なし）";
                    <option value="@sa.Id.Value">@label</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">特性 <span class="text-danger">*</span></label>
            <select class="form-select" @bind="SelectedAbilityId" @bind:after="() => SelectedAbilityIdChanged.InvokeAsync(SelectedAbilityId)" disabled="@(AvailableAbilities.Count == 0)">
                @if (AvailableAbilities.Count == 0)
                {
                    <option value="0">-- 種族を選択してください --</option>
                }
                else
                {
                    @foreach (var ability in AvailableAbilities)
                    {
                        <option value="@ability.Id.Value">@ability.Name</option>
                    }
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">能力ポイント <span class="text-danger">*</span></label>
            <div class="row g-2">
                <div class="col-2">
                    <label class="form-label small">HP</label>
                    <input type="number" class="form-control" min="0" max="32" @bind="StatPointHp" @bind:event="oninput" @bind:after="() => StatPointHpChanged.InvokeAsync(StatPointHp)" />
                </div>
                <div class="col-2">
                    <label class="form-label small">こうげき</label>
                    <input type="number" class="form-control" min="0" max="32" @bind="StatPointAttack" @bind:event="oninput" @bind:after="() => StatPointAttackChanged.InvokeAsync(StatPointAttack)" />
                </div>
                <div class="col-2">
                    <label class="form-label small">ぼうぎょ</label>
                    <input type="number" class="form-control" min="0" max="32" @bind="StatPointDefense" @bind:event="oninput" @bind:after="() => StatPointDefenseChanged.InvokeAsync(StatPointDefense)" />
                </div>
                <div class="col-2">
                    <label class="form-label small">とくこう</label>
                    <input type="number" class="form-control" min="0" max="32" @bind="StatPointSpecialAttack" @bind:event="oninput" @bind:after="() => StatPointSpecialAttackChanged.InvokeAsync(StatPointSpecialAttack)" />
                </div>
                <div class="col-2">
                    <label class="form-label small">とくぼう</label>
                    <input type="number" class="form-control" min="0" max="32" @bind="StatPointSpecialDefense" @bind:event="oninput" @bind:after="() => StatPointSpecialDefenseChanged.InvokeAsync(StatPointSpecialDefense)" />
                </div>
                <div class="col-2">
                    <label class="form-label small">すばやさ</label>
                    <input type="number" class="form-control" min="0" max="32" @bind="StatPointSpeed" @bind:event="oninput" @bind:after="() => StatPointSpeedChanged.InvokeAsync(StatPointSpeed)" />
                </div>
            </div>
            <small class="text-muted">合計: @StatPointTotal / 66</small>
            @if (StatPointTotal > 66)
            {
                <small class="text-danger ms-2">合計が66を超えています</small>
            }
        </div>

        <div class="mb-3">
            <label class="form-label">技1 <span class="text-danger">*</span></label>
            <input type="text" class="form-control mb-1" placeholder="技名で検索..." @bind="moveFilter1_" @bind:event="oninput" />
            <select class="form-select" @bind="SelectedMove1Id" @bind:after="() => SelectedMove1IdChanged.InvokeAsync(SelectedMove1Id)">
                <option value="0">-- 選択してください --</option>
                @foreach (var move in FilteredMoves1)
                {
                    <option value="@move.Id.Value">@move.Name</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">技2</label>
            <input type="text" class="form-control mb-1" placeholder="技名で検索..." @bind="moveFilter2_" @bind:event="oninput" />
            <select class="form-select" @bind="SelectedMove2Id" @bind:after="() => SelectedMove2IdChanged.InvokeAsync(SelectedMove2Id)">
                <option value="0">-- なし --</option>
                @foreach (var move in FilteredMoves2)
                {
                    <option value="@move.Id.Value">@move.Name</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">技3</label>
            <input type="text" class="form-control mb-1" placeholder="技名で検索..." @bind="moveFilter3_" @bind:event="oninput" />
            <select class="form-select" @bind="SelectedMove3Id" @bind:after="() => SelectedMove3IdChanged.InvokeAsync(SelectedMove3Id)">
                <option value="0">-- なし --</option>
                @foreach (var move in FilteredMoves3)
                {
                    <option value="@move.Id.Value">@move.Name</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">技4</label>
            <input type="text" class="form-control mb-1" placeholder="技名で検索..." @bind="moveFilter4_" @bind:event="oninput" />
            <select class="form-select" @bind="SelectedMove4Id" @bind:after="() => SelectedMove4IdChanged.InvokeAsync(SelectedMove4Id)">
                <option value="0">-- なし --</option>
                @foreach (var move in FilteredMoves4)
                {
                    <option value="@move.Id.Value">@move.Name</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">持ち物</label>
            <input type="text" class="form-control mb-1" placeholder="道具名で検索..." @bind="itemFilter_" @bind:event="oninput" />
            <select class="form-select" @bind="SelectedHeldItemId" @bind:after="() => SelectedHeldItemIdChanged.InvokeAsync(SelectedHeldItemId)">
                <option value="0">-- なし --</option>
                @foreach (var item in FilteredItems)
                {
                    <option value="@item.Id.Value">@item.Name</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">テラスタイプ <span class="text-danger">*</span></label>
            <select class="form-select" @bind="SelectedTeraTypeId" @bind:after="() => SelectedTeraTypeIdChanged.InvokeAsync(SelectedTeraTypeId)">
                @foreach (var type in TeraTypeOptions)
                {
                    <option value="@type.Id.Value">@type.Name</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">メモ</label>
            <textarea class="form-control" rows="3" @bind="Memo" @bind:after="() => MemoChanged.InvokeAsync(Memo)"></textarea>
        </div>

        <div class="mb-3">
            <button class="btn btn-primary me-2" @onclick="OnSubmit" disabled="@(!IsValid || IsSubmitting)">
                @(IsSubmitting ? "保存中..." : SubmitLabel)
            </button>
            <a class="btn btn-secondary" href="individuals">キャンセル</a>
        </div>

        @if (ErrorMessage is not null)
        {
            <div class="alert alert-danger">@ErrorMessage</div>
        }
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">Lv.50 実数値</div>
            <div class="card-body">
                @if (CalculatedStats is not null)
                {
                    <table class="table table-sm mb-0">
                        <tr><td>HP</td><td class="text-end"><strong>@CalculatedStats.Hp</strong></td></tr>
                        <tr><td>こうげき</td><td class="text-end"><strong>@CalculatedStats.Attack</strong></td></tr>
                        <tr><td>ぼうぎょ</td><td class="text-end"><strong>@CalculatedStats.Defense</strong></td></tr>
                        <tr><td>とくこう</td><td class="text-end"><strong>@CalculatedStats.SpecialAttack</strong></td></tr>
                        <tr><td>とくぼう</td><td class="text-end"><strong>@CalculatedStats.SpecialDefense</strong></td></tr>
                        <tr><td>すばやさ</td><td class="text-end"><strong>@CalculatedStats.Speed</strong></td></tr>
                    </table>
                }
                else
                {
                    <p class="text-muted mb-0">種族を選択すると実数値が表示されます</p>
                }
            </div>
        </div>
    </div>
</div>
