@page "/individuals"
@rendermode InteractiveServer

<PageTitle>手持ち管理</PageTitle>

<h1>手持ち管理</h1>

<div class="mb-3">
    <Button Href="individuals/new">新規登録</Button>
</div>

@if (isLoading_)
{
    <p>読み込み中...</p>
}
else if (individuals_.Count == 0)
{
    <Alert Variant="AlertVariant.Info">手持ち個体がまだ登録されていません。</Alert>
}
else
{
    <table class="app-table">
        <thead>
            <tr>
                <th>表示名</th>
                <th>種族</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var individual in individuals_)
            {
                <tr>
                    <td>@individual.DisplayName</td>
                    <td>@individual.SpeciesName</td>
                    <td>
                        <Button Variant="ButtonVariant.OutlinePrimary" Size="ButtonSize.Small" Href="@($"individuals/{individual.Id}/edit")" class="me-1">編集</Button>
                        <Button Variant="ButtonVariant.OutlineDanger" Size="ButtonSize.Small" OnClick="() => OnDeleteClick(individual.Id)">削除</Button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (showDeleteConfirm_)
{
    <div class="fixed inset-0 z-[1050] bg-black/50" tabindex="-1">
        <div class="max-w-[500px] mx-auto mt-7">
            <div class="bg-white rounded-lg shadow-lg">
                <div class="flex items-center justify-between p-4 border-b border-[#dee2e6]">
                    <h5 class="text-xl font-medium">削除確認</h5>
                    <button type="button"
                            class="bg-transparent border-0 opacity-50 p-2 w-6 h-6 cursor-pointer hover:opacity-75 bg-center bg-[length:1em_auto] bg-no-repeat"
                            style="background-image: url(&quot;data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='%23000'%3e%3cpath d='M.293.293a1 1 0 0 1 1.414 0L8 6.586 14.293.293a1 1 0 1 1 1.414 1.414L9.414 8l6.293 6.293a1 1 0 0 1-1.414 1.414L8 9.414l-6.293 6.293a1 1 0 0 1-1.414-1.414L6.586 8 .293 1.707a1 1 0 0 1 0-1.414z'/%3e%3c/svg%3e&quot;)"
                            @onclick="CancelDelete">
                    </button>
                </div>
                <div class="p-4">
                    @if (deleteIsInParty_)
                    {
                        <Alert Variant="AlertVariant.Warning" class="mb-2">この個体はパーティに所属しています。削除するとパーティのスロットが空になります。</Alert>
                    }
                    <p>この個体を削除しますか？</p>
                </div>
                <div class="flex justify-end gap-2 p-4 border-t border-[#dee2e6]">
                    <Button Variant="ButtonVariant.Secondary" OnClick="CancelDelete">キャンセル</Button>
                    <Button Variant="ButtonVariant.Danger" OnClick="ConfirmDelete">削除</Button>
                </div>
            </div>
        </div>
    </div>
}

@if (errorMessage_ is not null)
{
    <Alert Variant="AlertVariant.Danger" class="mt-3">@errorMessage_</Alert>
}
