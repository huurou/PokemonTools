@page "/admin/master-data-import"
@rendermode InteractiveServer

<PageTitle>マスターデータ更新</PageTitle>

<h1>マスターデータ更新</h1>

<p>PokeAPIからマスターデータを取得してDBに保存します。</p>

<div class="mb-3">
    <Button OnClick="ImportAll" Disabled="@isRunning_" class="me-2">全データインポート</Button>
    <Button Variant="ButtonVariant.OutlineSecondary" OnClick="ImportItems" Disabled="@isRunning_" class="me-2">道具</Button>
    <Button Variant="ButtonVariant.OutlineSecondary" OnClick="ImportMoves" Disabled="@isRunning_" class="me-2">技</Button>
    <Button Variant="ButtonVariant.OutlineSecondary" OnClick="ImportAbilitiesAndSpecies" Disabled="@isRunning_" class="me-2">特性・種族</Button>
    @if (isRunning_)
    {
        <Button Variant="ButtonVariant.Danger" OnClick="CancelImport">キャンセル</Button>
    }
</div>

@if (isRunning_ && currentProgress_ is not null)
{
    var percentage = currentProgress_.Total > 0
        ? currentProgress_.Current * 100.0 / currentProgress_.Total
        : 0.0;
    var percentageText = percentage.ToString("F2");

    <div class="mb-3">
        <strong>@currentProgress_.Category</strong> インポート中...
        @currentProgress_.Current / @currentProgress_.Total 件 (@percentageText%)
        @if (currentProgress_.CurrentName is not null)
        {
            <span class="text-[#6c757d] ms-2">@currentProgress_.CurrentName</span>
        }
    </div>

    <div class="flex overflow-hidden bg-[#e9ecef] rounded-md h-6 mb-3">
        <div class="flex flex-col justify-center overflow-hidden text-white text-center whitespace-nowrap bg-primary transition-[width] duration-600 ease-out bg-[length:1rem_1rem] bg-[linear-gradient(45deg,rgba(255,255,255,0.15)_25%,transparent_25%,transparent_50%,rgba(255,255,255,0.15)_50%,rgba(255,255,255,0.15)_75%,transparent_75%,transparent)] animate-[progress-stripes_1s_linear_infinite]"
             role="progressbar"
             style="width: @(percentageText)%"
             aria-valuenow="@percentageText"
             aria-valuemin="0"
             aria-valuemax="100">
        </div>
    </div>
}

@if (status_ == ImportStatus.Completed)
{
    <Alert Variant="AlertVariant.Success">インポートが完了しました。</Alert>
}

@if (status_ == ImportStatus.Cancelled)
{
    <Alert Variant="AlertVariant.Warning">インポートがキャンセルされました。</Alert>
}

@if (errorMessage_ is not null)
{
    <Alert Variant="AlertVariant.Danger">エラー: @errorMessage_</Alert>
}
