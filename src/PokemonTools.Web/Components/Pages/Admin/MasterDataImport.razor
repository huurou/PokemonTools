@page "/admin/master-data-import"
@rendermode InteractiveServer

<PageTitle>マスターデータ更新</PageTitle>

<h1>マスターデータ更新</h1>

<p>PokeAPIからマスターデータを取得してDBに保存します。</p>

<div class="mb-3">
    <button class="btn btn-primary me-2" @onclick="ImportAll" disabled="@isRunning_">全データインポート</button>
    <button class="btn btn-outline-secondary me-2" @onclick="ImportItems" disabled="@isRunning_">道具</button>
    <button class="btn btn-outline-secondary me-2" @onclick="ImportMoves" disabled="@isRunning_">技</button>
    <button class="btn btn-outline-secondary me-2" @onclick="ImportAbilitiesAndSpecies" disabled="@isRunning_">特性・種族</button>
    @if (isRunning_)
    {
        <button class="btn btn-danger" @onclick="CancelImport">キャンセル</button>
    }
</div>

@if (isRunning_ && currentProgress_ is not null)
{
    var percentage = currentProgress_.Total > 0
        ? currentProgress_.Current * 100.0 / currentProgress_.Total
        : 0.0;
    var percentageText = percentage.ToString("F2");

    <div class="mb-3">
        <strong>@currentProgress_.Category</strong> インポート中...
        @currentProgress_.Current / @currentProgress_.Total 件 (@percentageText%)
        @if (currentProgress_.CurrentName is not null)
        {
            <span class="text-muted ms-2">@currentProgress_.CurrentName</span>
        }
    </div>

    <div class="progress mb-3" style="height: 24px;">
        <div class="progress-bar progress-bar-striped progress-bar-animated"
             role="progressbar"
             style="width: @(percentageText)%"
             aria-valuenow="@percentageText"
             aria-valuemin="0"
             aria-valuemax="100">
        </div>
    </div>
}

@if (status_ == ImportStatus.Completed)
{
    <div class="alert alert-success">インポートが完了しました。</div>
}

@if (status_ == ImportStatus.Cancelled)
{
    <div class="alert alert-warning">インポートがキャンセルされました。</div>
}

@if (errorMessage_ is not null)
{
    <div class="alert alert-danger">エラー: @errorMessage_</div>
}
