<Project>
  <Target Name="_TailwindCompile"
          Condition="Exists('$(MSBuildProjectDirectory)/Styles/app.css')">
    <Exec Command="npx @tailwindcss/cli -i Styles/app.css -o wwwroot/app.generated.css --minify"
          WorkingDirectory="$(MSBuildProjectDirectory)"
          StandardOutputImportance="Low"
          StandardErrorImportance="Low" />
  </Target>

  <Target Name="TailwindBuild" BeforeTargets="Build" DependsOnTargets="_TailwindCompile" />
  <Target Name="TailwindPublish" BeforeTargets="Publish" DependsOnTargets="_TailwindCompile" />

  <ItemGroup Condition="Exists('$(MSBuildProjectDirectory)/Styles')">
    <Content Remove="Styles\**" />
  </ItemGroup>
</Project>
